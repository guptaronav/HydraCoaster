	<string>HydraCoaster logs each sip as water intake in Health.</string>
	<key>OWMAPIKey</key>
	<string>$(OWM_API_KEY)</string>
	<key>OWMLat</key>
	<string>$(OWM_LAT)</string>
	<key>OWMLon</key>
	<string>$(OWM_LON)</string>
